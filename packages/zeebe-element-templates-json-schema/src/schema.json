{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "http://camunda.org/schema/zeebe-element-templates/1.0",
  "title": "Element Template Schema",
  "definitions": {
    "properties": {
      "allOf": [
        {
          "$ref": "../../packages/element-templates-json-schema-shared/src/defs/base-properties.json"
        },
        {
          "$ref": "src/defs/properties.json"
        }
      ]
    },
    "template": {
      "type": "object",
      "allOf": [
        {
          "$ref": "../../packages/element-templates-json-schema-shared/src/defs/base.json"
        },
        {
          "$ref": "src/defs/template.json"
        },
        {
          "$ref": "src/defs/feel-required.json"
        }
      ],
      "properties": {
        "properties": {
          "$ref": "#/definitions/properties",
          "$id": "#/properties"
        },
        "engines": {
          "$ref": "src/defs/engines.json"
        },
        "category": {
          "$ref": "src/defs/category.json"
        },
        "icon": {
          "$ref": "src/defs/icon.json"
        },
        "elementType": {
          "allOf": [
            {
              "$ref": "src/defs/element-type.json"
            }
          ]
        },
        "groups": {
          "$ref": "src/defs/groups.json"
        },
        "entriesVisible": {
          "$id": "#/entriesVisible",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "object",
              "properties": {
                "outputs": {
                  "type": "boolean",
                  "default": false
                },
                "executionListeners": {
                  "type": "boolean",
                  "default": true
                },
                "userTaskListeners": {
                  "type": "boolean",
                  "default": false
                }
              },
              "additionalProperties": false
            }
          ],
          "description": "Defines whether standard property groups, normally hidden by the template, are shown. When set to true, all standard groups are shown. When set to an object, specified standard groups are additionally shown (e.g. { \"outputs\": true })."
        }
      }
    }
  },
  "oneOf": [
    {
      "description": "An element template configuration.",
      "$ref": "#/definitions/template"
    },
    {
      "type": "array",
      "description": "A list of element template configurations.",
      "items": {
        "$ref": "#/definitions/template"
      }
    }
  ]
}