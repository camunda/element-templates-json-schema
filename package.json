{
  "name": "element-templates-json-schema-build",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "dev": "run-s build \"workspace-dev -- {@}\" -- ",
    "workspace-dev": "npm run dev --workspace",
    "build": "npm run build --workspaces --if-present",
    "build:camunda": "npm run build --workspace @camunda/element-templates-json-schema",
    "build:zeebe": "npm run build --workspace @camunda/zeebe-element-templates-json-schema",
    "build:zeebe-configuration": "npm run build --workspace @camunda/zeebe-configuration-templates-json-schema",
    "all": "run-s build lint test",
    "release": "npx @bpmn-io/release",
    "fetch:connector-templates": "node tasks/fetch-connector-templates.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camunda/element-templates-json-schema.git"
  },
  "keywords": [
    "json-schema",
    "element-templates",
    "camunda"
  ],
  "workspaces": [
    "packages/element-templates-json-schema-shared",
    "packages/element-templates-json-schema",
    "packages/zeebe-configuration-templates-json-schema",
    "packages/zeebe-element-templates-json-schema"
  ],
  "author": "Niklas Kiefer <niklas.kiefer@camunda.com (https://github.com/pinussilvestrus)",
  "contributors": [
    {
      "name": "bpmn.io contributors",
      "url": "https://github.com/bpmn-io"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/camunda/element-templates-json-schema/issues"
  },
  "homepage": "https://github.com/camunda/element-templates-json-schema#readme",
  "devDependencies": {
    "@bpmn-io/release": "^0.3.0",
    "@apidevtools/json-schema-ref-parser": "^15.0.0",
    "ajv": "^7.2.3",
    "ajv-errors": "^2.0.1",
    "chai": "^6.2.2",
    "eslint": "^10.0.0",
    "eslint-plugin-bpmn-io": "^2.2.0",
    "min-dash": "^5.0.0",
    "mocha": "^11.7.5",
    "mri": "^1.2.0",
    "npm-run-all2": "^9.0.0"
  },
  "releaseConfig": {
    "strategy": "independent"
  }
}
